@startuml vista_fisica
title Vista Física - Infraestructura de Despliegue en AWS\nArquitectura de Software - Grupo [X] - PUJ 2026

skinparam backgroundColor #F8FAFC
skinparam node {
  BackgroundColor #DBEAFE
  BorderColor #1D4ED8
  FontColor #1E3A8A
  FontStyle Bold
}
skinparam component {
  BackgroundColor #ECFDF5
  BorderColor #059669
  FontColor #064E3B
}
skinparam database {
  BackgroundColor #FEF3C7
  BorderColor #D97706
  FontColor #78350F
}
skinparam queue {
  BackgroundColor #F3E8FF
  BorderColor #7C3AED
  FontColor #4C1D95
}
skinparam cloud {
  BackgroundColor #E0F2FE
  BorderColor #0284C7
}
skinparam arrow {
  Color #374151
  FontColor #6B7280
  FontSize 10
}

cloud "Internet" {
  actor "Estudiantes\n& Docentes" as Users
}

node "AWS - Region us-east-1" {

  node "CloudFront CDN\n(Edge Locations Globales)" {
    component [React SPA\n(S3 Bucket)\nAssets estáticos cacheados] as Frontend
  }

  node "VPC - Red Privada" {

    node "Subnet Pública\n(Acceso desde Internet)" {
      component [AWS API Gateway\nJWT Validation\nRate Limiting (100 req/min)\nRouting a servicios] as APIGateway
    }

    node "Subnet Privada - Capa de Servicios\n(ECS Fargate - Sin acceso directo desde Internet)" {

      node "ECS Cluster" {
        component [User Service\n2-6 instancias\n0.5 vCPU / 1 GB RAM\nPort: 3001] as UserSvc
        component [Course Service\n2-6 instancias\n0.5 vCPU / 1 GB RAM\nPort: 3002] as CourseSvc
        component [Assessment &\nAdaptive Service\n3-10 instancias [auto-scaling]\n1 vCPU / 2 GB RAM\nPort: 3003] as AssessmentSvc
        component [Collaboration Service\n1-4 instancias\n0.5 vCPU / 1 GB RAM\nPort: 3004] as CollabSvc
        component [Analytics Service\n1-4 instancias\n1 vCPU / 2 GB RAM\nPort: 3005] as AnalyticsSvc
      }

    }

    node "Subnet Privada - Capa de Datos\n(Sin acceso desde Internet ni desde servicios directamente)" {

      database "AWS RDS PostgreSQL 16\n(db.t3.large - 2 vCPU / 8 GB)\nMulti-AZ (failover < 60 seg)\n100 GB SSD (gp3)\nschemas: users | courses | assessments | collaboration | analytics\nBackups: diarios, retención 7 días" as PrimaryDB

      database "RDS Read Replica\n(Misma región)\nPara consultas analíticas\n(Analytics Service)" as ReadReplica

      database "AWS ElastiCache Redis 7\n(cache.t3.medium)\nSesiones JWT (TTL 8h)\nCaché de contenido (TTL 5min)\nEstado de evaluaciones en progreso" as RedisCache

      queue "AWS MQ - RabbitMQ 3.12\n(mq.m5.large - Administrado)\nEventos asíncronos:\nevaluation.completed\nevaluation.failed_threshold\nlesson.completed" as RabbitMQ

      component [AWS S3\nMateriales educativos\nPDFs, imágenes\nDurabilidad 99.999999999%] as S3

    }

    node "Observabilidad" {
      component [AWS CloudWatch\nLogs estructurados JSON\nMétricas de ECS, RDS, MQ\nAlertas automáticas] as CloudWatch
      component [AWS X-Ray\nDistributed Tracing\nCorrelation IDs entre servicios\nLatencia por servicio] as XRay
    }

  }

  node "CI/CD Pipeline" {
    component [GitHub Actions\nlint → test → build → push ECR\n→ deploy Staging → smoke tests\n→ deploy Production (Blue-Green)] as CICD
    component [AWS ECR\nRegistro de imágenes Docker\npor servicio] as ECR
  }

}

'' Conexiones externas → internet
Users --> Frontend : "HTTPS (CloudFront)"
Frontend --> APIGateway : "HTTPS /api/v1/*"

'' API Gateway → servicios
APIGateway --> UserSvc : "HTTP (VPC interno)"
APIGateway --> CourseSvc : "HTTP (VPC interno)"
APIGateway --> AssessmentSvc : "HTTP (VPC interno)"
APIGateway --> CollabSvc : "HTTP (VPC interno)"
APIGateway --> AnalyticsSvc : "HTTP (VPC interno)"

'' Servicios → capa de datos
UserSvc --> PrimaryDB : "TCP 5432 (schema_users)"
CourseSvc --> PrimaryDB : "TCP 5432 (schema_courses)"
AssessmentSvc --> PrimaryDB : "TCP 5432 (schema_assessments)"
AssessmentSvc --> RedisCache : "TCP 6379 (caché reglas)"
CollabSvc --> PrimaryDB : "TCP 5432 (schema_collaboration)"
AnalyticsSvc --> ReadReplica : "TCP 5432 (schema_analytics - solo lectura)"
CourseSvc --> S3 : "HTTPS (materialUpload/download)"

'' Assessment → RabbitMQ (publica)
AssessmentSvc --> RabbitMQ : "AMQP 5672\n(publica eventos)"

'' Consumidores de eventos
RabbitMQ --> AnalyticsSvc : "AMQP (consume evaluation.completed)"
RabbitMQ --> CollabSvc : "AMQP (consume evaluation.failed_threshold)"

'' Replicación DB
PrimaryDB --> ReadReplica : "Replicación síncrona\nMulti-AZ"

'' Monitoreo
UserSvc --> CloudWatch : "logs + métricas"
AssessmentSvc --> CloudWatch : "logs + métricas"
AnalyticsSvc --> CloudWatch : "logs + métricas"
AssessmentSvc --> XRay : "distributed tracing"

'' CI/CD
CICD --> ECR : "docker push"
CICD --> UserSvc : "ECS deploy (Blue-Green)"
CICD --> AssessmentSvc : "ECS deploy (Blue-Green)"

note bottom of AssessmentSvc
  **Auto-scaling:**
  - Mínimo: 3 instancias
  - Máximo: 10 instancias
  - Trigger: CPU > 80% por 3 min
  - Escala en < 5 minutos
  Absorbe picos de evaluaciones masivas
  (inicio/fin de semestre)
end note

note right of PrimaryDB
  **PgBouncer (Connection Pooling):**
  Gestiona conexiones concurrentes
  de ECS hacia RDS.
  Evita saturación de conexiones
  bajo 5,000 usuarios concurrentes.
end note

@enduml


