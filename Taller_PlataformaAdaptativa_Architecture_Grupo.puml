package "Dominio de Usuarios\n(User Domain)" {
  class UserController {
    +register()
    +login()
    +logout()
    +updateProfile()
  }
  class UserApplicationService {
    +createUser()
    +authenticate()
    +authorize(role)
  }
  class UserRepository {
    +findByEmail()
    +save()
    +update()
  }
  class User {
    -id: UUID
    -email: String
    -passwordHash: String
    -role: Enum [student, instructor, admin]
    -createdAt: DateTime
  }
  UserController --> UserApplicationService
  UserApplicationService --> UserRepository
  UserRepository --> User
}

package "Dominio de Cursos\n(Course Domain)" {
  class CourseController {
    +createCourse()
    +publishCourse()
    +getCourseMaterials()
    +enrollStudent()
  }
  class CourseApplicationService {
    +createCourse()
    +addLesson()
    +enrollStudent()
    +getEnrolledCourses()
  }
  class CourseRepository {
    +save()
    +findById()
    +findByInstructor()
  }
  class Course {
    -id: UUID
    -title: String
    -description: String
    -status: Enum [draft, published]
    -modules: List<Module>
  }
  class Module {
    -id: UUID
    -title: String
    -lessons: List<Lesson>
    -order: Integer
  }
  class Lesson {
    -id: UUID
    -title: String
    -contentType: Enum [video, pdf, text]
    -contentUrl: String
  }
  CourseController --> CourseApplicationService
  CourseApplicationService --> CourseRepository
  CourseRepository --> Course
  Course "1" *-- "many" Module
  Module "1" *-- "many" Lesson
}

package "Dominio de Evaluaciones y Adaptación\n(Assessment & Adaptive Domain)" {
  class AssessmentController {
    +createQuiz()
    +submitAnswers()
    +getResult()
  }
  class AssessmentApplicationService {
    +gradeSubmission()
    +evaluateAdaptiveRules()
    +determineNextStep()
  }
  class AdaptiveRulesEngine {
    +evaluate(result, rules): NextStep
    -loadRules(lessonId)
    -checkThreshold(score, threshold)
  }
  class AssessmentRepository {
    +saveResult()
    +findByStudentAndLesson()
  }
  class AdaptiveRule {
    -lessonId: UUID
    -approvalThreshold: Integer
    -reinforcementMaterialIds: List<UUID>
    -advancedContentId: UUID
    -maxAttempts: Integer
  }
  class AssessmentResult {
    -id: UUID
    -studentId: UUID
    -quizId: UUID
    -score: Integer
    -completedAt: DateTime
    -nextStep: NextStep
  }
  AssessmentController --> AssessmentApplicationService
  AssessmentApplicationService --> AdaptiveRulesEngine
  AssessmentApplicationService --> AssessmentRepository
  AdaptiveRulesEngine --> AdaptiveRule
  AssessmentRepository --> AssessmentResult
}

package "Dominio de Colaboración\n(Collaboration Domain)" {
  class CollaborationController {
    +createForum()
    +postMessage()
    +createStudyGroup()
    +findTutors()
  }
  class CollaborationApplicationService {
    +postForumMessage()
    +createStudyGroup()
    +identifyTutorCandidates()
  }
  class Forum {
    -id: UUID
    -courseId: UUID
    -title: String
    -threads: List<Thread>
  }
  class StudyGroup {
    -id: UUID
    -name: String
    -members: List<UUID>
    -maxMembers: Integer
  }
  CollaborationController --> CollaborationApplicationService
  CollaborationApplicationService --> Forum
  CollaborationApplicationService --> StudyGroup
}

package "Dominio de Analítica\n(Analytics Domain)" {
  class AnalyticsController {
    +getStudentProgress()
    +getCourseReport()
    +exportReport()
  }
  class AnalyticsApplicationService {
    +updateProgress()
    +generateCourseReport()
    +detectAtRiskStudents()
  }
  class ProgressRecord {
    -studentId: UUID
    -courseId: UUID
    -completionPercentage: Float
    -averageScore: Float
    -lastActivityAt: DateTime
  }
  AnalyticsController --> AnalyticsApplicationService
  AnalyticsApplicationService --> ProgressRecord
}

'' Relaciones entre dominios (solo a través de eventos/contratos)
AssessmentApplicationService ..> AnalyticsApplicationService : "event: evaluation.completed\n(async via RabbitMQ)"
AssessmentApplicationService ..> CollaborationApplicationService : "event: evaluation.failed_threshold\n(async via RabbitMQ)"
CourseApplicationService ..> UserApplicationService : "verifica inscripción"

@enduml


