== FLUJO 1: Autenticación de Usuario (RF-08) ==

actor "Estudiante" as Student
participant "Web Client\n(React SPA)" as WebApp
participant "API Gateway\n(JWT Validation)" as GW
participant "User Service\n(Node.js)" as UserSvc
database "Redis\n(Sessions)" as Redis
database "PostgreSQL\n(schema_users)" as PG

Student -> WebApp : Ingresa email + password
WebApp -> GW : POST /api/v1/auth/login
GW -> UserSvc : Enruta (sin validación JWT en login)
UserSvc -> PG : SELECT user WHERE email = ?
PG --> UserSvc : User record
UserSvc -> UserSvc : bcrypt.verify(password, hash)
note right : Verificación segura\n(costo 12)
UserSvc -> UserSvc : generateJWT(userId, role, exp=8h)
UserSvc -> Redis : SET session:{userId} = jwt (TTL 8h)
UserSvc --> GW : {token: JWT, user: {...}}
GW --> WebApp : 200 OK + JWT
WebApp -> WebApp : Almacena JWT en memoria\n(NO en localStorage)
Student <-- WebApp : Dashboard principal

== FLUJO 2: Estudiante Completa una Evaluación - Camino Crítico (RF-02, RF-03, DR-01) ==

actor "Estudiante" as S
participant "Web Client" as WC
participant "API Gateway" as GW2
participant "Assessment &\nAdaptive Service" as AS
database "Redis" as R2
database "PostgreSQL\n(schema_assessments)" as PG2
queue "RabbitMQ" as MQ

S -> WC : Envía respuestas del quiz
WC -> GW2 : POST /api/v1/assessments/{quizId}/submit\nAuthorization: Bearer JWT
GW2 -> GW2 : Valida JWT (firma RS256)\n~10ms
GW2 -> AS : POST /submit (enruta petición)

group Camino Crítico Síncrono [~120ms total, responde al usuario]
  AS -> PG2 : SELECT quiz, questions WHERE id = {quizId}\n~30ms
  PG2 --> AS : Quiz con respuestas correctas
  AS -> AS : calculateScore(answers, correct)\n~5ms
  AS -> R2 : GET adaptive_rules:{lessonId} (caché)\n~5ms
  R2 --> AS : AdaptiveRule (caché hit) o NULL
  note right AS : Si caché miss: consulta PG\n(reglas cargadas por docente)
  AS -> AS : evaluateRules(score, rule)\ndetermineNextStep()\n~5ms
  AS -> PG2 : INSERT assessment_result {...}\n~30ms
  PG2 --> AS : OK (ACID commit)
  AS -> MQ : PUBLISH "evaluation.completed"\n{studentId, quizId, score, lessonId}\n~10ms
  note right MQ : Fire-and-forget\nNo bloquea la respuesta
  AS --> GW2 : {score: 85, passed: true, nextStep: "advanced_content_id_X"}
  GW2 --> WC : 200 OK + resultado
  S <-- WC : "Obtuviste 85/100 ✅\nTu próxima lección: [Contenido Avanzado]"
end

== FLUJO 3: Procesamiento Asíncrono Post-Evaluación (DR-03, DR-05) ==

queue "RabbitMQ" as MQ3
participant "Analytics\nService" as AnSvc
participant "Collaboration\nService" as CollSvc
participant "Notification\nService" as NotSvc
database "PostgreSQL\n(schema_analytics)" as PG3

MQ3 -> AnSvc : CONSUME "evaluation.completed"
note right AnSvc : Procesamiento en background\nsin afectar la experiencia del usuario
AnSvc -> PG3 : UPDATE progress_record\nSET completion_percentage, average_score\n~200ms (fuera del camino crítico)
PG3 --> AnSvc : OK

MQ3 -> CollSvc : CONSUME "evaluation.failed_threshold"\n(si score < umbral)
CollSvc -> CollSvc : identifyTutorCandidates(lessonId)\n(estudiantes con score > 85%)

MQ3 -> NotSvc : CONSUME "evaluation.completed"
NotSvc -> NotSvc : sendEmailNotification(instructor)\n(si > 30% estudiantes reprueban)

note over MQ3
  **Resiliencia:**
  Si Analytics Service cae, los mensajes
  se persisten en RabbitMQ.
  Cuando el servicio se recupera,
  procesa la cola acumulada.
  Los datos NO se pierden.
end note

== FLUJO 4: Docente Configura Regla de Adaptación (RF-03, DR-05) ==

actor "Docente" as T
participant "Web Client" as WC4
participant "API Gateway" as GW4
participant "Course Service" as CS
database "PostgreSQL\n(schema_courses)" as PG4

T -> WC4 : Modifica umbral de aprobación: 70% → 80%\nAgrega material de refuerzo [ID: xyz]
WC4 -> GW4 : PUT /api/v1/courses/{courseId}/lessons/{lessonId}/adaptive-rules\nBody: {threshold: 80, reinforcement: ["xyz"]}
GW4 -> GW4 : Valida JWT + verifica role == "instructor"
GW4 -> CS : PUT /adaptive-rules
CS -> PG4 : UPDATE adaptive_rules SET threshold=80, reinforcement_ids=[...]\n~20ms
PG4 --> CS : OK
CS --> GW4 : 200 OK
GW4 --> WC4 : Reglas actualizadas exitosamente
T <-- WC4 : "✅ Reglas de adaptación actualizadas\nEfectivas para la próxima evaluación"

note right PG4
  Las reglas están en la BD, NO en el código.
  La próxima evaluación de cualquier
  estudiante usará las nuevas reglas
  sin necesidad de redespliegue.
end note

@enduml


