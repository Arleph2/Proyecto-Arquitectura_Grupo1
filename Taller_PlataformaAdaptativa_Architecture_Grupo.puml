  BackgroundColor #FFFBEB
  BorderColor #D97706
  FontColor #78350F
}
skinparam arrow {
  Color #374151
}

left to right direction

actor "Estudiante" as S
actor "Docente" as T
actor "Administrador" as A

rectangle "Plataforma de Aprendizaje Adaptativo y Colaborativo" {

  ' Escenario 1 - Core
  usecase "UC-01: Completar Evaluación\ny Recibir Adaptación" as UC1
  note right of UC1
    **Escenario Crítico - DR-01, DR-07**
    1. Estudiante envía respuestas
    2. Sistema califica (< 50ms)
    3. Motor evalúa reglas adaptativas
    4. Responde con resultado + siguiente paso
    **Total: < 2 segundos P95**
    Analytics se actualiza async (RabbitMQ)
  end note

  ' Escenario 2
  usecase "UC-02: Acceder a Contenido\ndel Curso" as UC2
  note right of UC2
    **DR-01: Rendimiento**
    Lista de cursos: Redis caché (< 10ms)
    Materiales: S3 via CloudFront (< 200ms)
    Sin consulta a DB en lecturas frecuentes
  end note

  ' Escenario 3
  usecase "UC-03: Pico de 500 Evaluaciones\nSimultáneas" as UC3
  note right of UC3
    **DR-02: Escalabilidad**
    Assessment Service: 3 → 8 instancias (< 5 min)
    RabbitMQ absorbe 500 eventos/seg
    P95 latencia se mantiene < 2 seg
    PgBouncer gestiona conexiones DB
  end note

  ' Escenario 4
  usecase "UC-04: Analytics Service Cae\nDurante Evaluaciones" as UC4
  note right of UC4
    **DR-03: Disponibilidad - Resiliencia**
    Estudiantes siguen completando evaluaciones ✅
    Eventos se acumulan en RabbitMQ (persistidos)
    Cuando Analytics se recupera: procesa cola
    Datos NO se pierden - Disponibilidad: 99.5%
  end note

  ' Escenario 5
  usecase "UC-05: Docente Configura\nReglas Adaptativas" as UC5
  note right of UC5
    **DR-05: Mantenibilidad, DR-07: Motor Adaptativo**
    Docente cambia umbral: 70% → 80%
    Se persiste en PostgreSQL
    Sin redespliegue del sistema
